<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>Panel Admin - Simulación</title>

<style>
body{
    margin:0;
    font-family:"Segoe UI";
    background:#0f172a;
    color:#fff;
}

header{
    padding:15px 30px;
    background:#020617;
    font-weight:bold;
    font-size:18px;
}

.container{
    padding:30px;
}

/* cards */
.stats{
    display:flex;
    gap:20px;
    margin-bottom:25px;
}

.card{
    background:#1e293b;
    padding:20px;
    border-radius:10px;
    flex:1;
}

.card h2{
    margin:0;
    font-size:28px;
}

/* tabla */
table{
    width:100%;
    border-collapse:collapse;
    background:#1e293b;
    border-radius:10px;
    overflow:hidden;
}

th, td{
    padding:12px;
    border-bottom:1px solid #334155;
    font-size:14px;
}

th{
    background:#020617;
    text-align:left;
}

/* botones */
.actions{
    margin:20px 0;
}

button{
    padding:10px 15px;
    margin-right:10px;
    border:none;
    border-radius:6px;
    cursor:pointer;
    font-weight:500;
}

.export{
    background:#16a34a;
    color:#fff;
}

.clear{
    background:#dc2626;
    color:#fff;
}

input{
    padding:8px;
    margin-bottom:10px;
    width:300px;
}

</style>

</head>

<body>

<header>
Panel de Resultados - Simulación de Phishing
</header>

<div class="container">

<div class="stats">
    <div class="card">
        <div>Total registros</div>
        <h2 id="total">0</h2>
    </div>

    <div class="card">
        <div>Usuarios únicos</div>
        <h2 id="usuarios">0</h2>
    </div>
</div>

<input id="filtro" placeholder="Filtrar por correo..." onkeyup="filtrar()">

<div class="actions">
    <button class="export" onclick="exportar()">Exportar CSV</button>
    <button class="clear" onclick="limpiar()">Limpiar logs</button>
</div>

<table>
    <thead>
        <tr>
            <th>Usuario</th>
            <th>Evento</th>
            <th>Fecha</th>
            <th>Dispositivo</th>
        </tr>
    </thead>
    <tbody id="tabla"></tbody>
</table>

</div>

<script>

let data = JSON.parse(localStorage.getItem("logs") || "[]");

function render(lista){
    let tabla = document.getElementById("tabla");
    tabla.innerHTML = "";

    lista.reverse().forEach(item=>{
        let row = `
        <tr>
            <td>${item.usuario}</td>
            <td>${item.evento}</td>
            <td>${new Date(item.fecha).toLocaleString()}</td>
            <td>${item.userAgent || "-"}</td>
        </tr>`;
        tabla.innerHTML += row;
    });

    actualizarStats(lista);
}

function actualizarStats(lista){
    document.getElementById("total").innerText = lista.length;

    let unicos = [...new Set(lista.map(i=>i.usuario))];
    document.getElementById("usuarios").innerText = unicos.length;
}

function filtrar(){
    let f = document.getElementById("filtro").value.toLowerCase();

    let filtrado = data.filter(i => i.usuario.toLowerCase().includes(f));
    render(filtrado);
}

function exportar(){
    let csv = "usuario,evento,fecha\n";

    data.forEach(i=>{
        csv += `${i.usuario},${i.evento},${i.fecha}\n`;
    });

    let blob = new Blob([csv], {type:"text/csv"});
    let url = URL.createObjectURL(blob);

    let a = document.createElement("a");
    a.href = url;
    a.download = "logs_simulacion.csv";
    a.click();
}

function limpiar(){
    if(confirm("¿Eliminar todos los registros?")){
        localStorage.removeItem("logs");
        location.reload();
    }
}

// inicial
render(data);

</script>

</body>
</html>
